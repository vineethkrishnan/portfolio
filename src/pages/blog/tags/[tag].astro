---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { tagToSlug } from "../../../lib/tags";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => !post.data.draft);
  const grouped = new Map<string, { name: string; posts: typeof posts }>();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      const slug = tagToSlug(tag);
      const bucket = grouped.get(slug);
      if (bucket) {
        bucket.posts.push(post);
      } else {
        grouped.set(slug, { name: tag, posts: [post] });
      }
    }
  }

  return Array.from(grouped.entries()).map(([slug, { name, posts: tagPosts }]) => ({
    params: { tag: slug },
    props: {
      name,
      posts: tagPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { name, posts } = Astro.props;
---

<BaseLayout
  title={`Posts tagged "${name}", Vineeth N K`}
  description={`All blog posts tagged ${name}.`}
>
  <section class="section">
    <div class="fade-in">
      <a href="/blog/tags/" class="tag-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
        </svg>
        All topics
      </a>
      <div class="section-label">
        <span class="section-label-line"></span>
        <span class="section-label-prefix">~/blog/tags/{name}</span>
      </div>
      <h1 class="section-title">Tagged "{name}"</h1>
      <p class="section-subtitle">
        {posts.length} {posts.length === 1 ? "post" : "posts"} under this topic.
      </p>
    </div>

    <div class="blog-list">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class="blog-card card fade-in"
          style={`transition-delay: ${i * 0.05}s`}
        >
          <div class="blog-card-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </div>
          <h2 class="blog-card-title">{post.data.title}</h2>
          <p class="blog-card-desc">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="blog-card-tags">
              {post.data.tags.map((postTag) => (
                <span class="tag">{postTag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .tag-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
    transition: color 0.2s ease;
  }

  .tag-back:hover {
    color: var(--color-accent);
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .blog-card:hover { color: var(--color-text); }

  .blog-card-meta {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .blog-card-title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-accent);
  }

  .blog-card-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
