---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog, Vineeth N K" description="Articles, tutorials, and insights about full stack development, CLI tools, and more.">
  <section class="section">
    <div class="fade-in">
      <h1 class="section-title">Blog</h1>
      <p class="section-subtitle">
        Thoughts on code, tools, and lessons learned along the way.
      </p>
      <div class="blog-toolbar">
        <a href="/blog/tags/" class="blog-toolbar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" /><line x1="7" y1="7" x2="7.01" y2="7" />
          </svg>
          Browse by topic
        </a>
        <a href="/rss.xml" class="blog-toolbar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9" /><path d="M4 4a16 16 0 0 1 16 16" /><circle cx="5" cy="19" r="1" />
          </svg>
          RSS feed
        </a>
      </div>
    </div>

    {posts.length === 0 ? (
      <div class="blog-empty fade-in">
        <p>No posts yet. Check back soon!</p>
      </div>
    ) : (
      <div class="blog-list">
        {posts.map((post, i) => (
          <a
            href={`/blog/${post.id}`}
            class="blog-card card fade-in"
            style={`transition-delay: ${i * 0.06}s`}
          >
            <div class="blog-card-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            </div>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="blog-card-tags">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
            <span class="blog-card-read">
              Read more
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .blog-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    margin-bottom: 2rem;
  }

  .blog-toolbar-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .blog-toolbar-link:hover {
    color: var(--color-accent);
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .blog-card:hover {
    color: var(--color-text);
  }

  .blog-card-meta {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .blog-card-title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-accent);
  }

  .blog-card-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .blog-card-read {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-accent);
    font-size: 0.88rem;
    font-weight: 600;
    margin-top: 0.25rem;
    transition: gap 0.2s ease;
  }

  .blog-card:hover .blog-card-read {
    gap: 0.75rem;
  }

  .blog-empty {
    text-align: center;
    padding: 4rem 0;
    color: var(--color-text-muted);
  }
</style>
