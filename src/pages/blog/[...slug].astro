---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import GiscusComments from "../../components/GiscusComments.astro";
import { readingTime } from "../../lib/reading-time";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

const reading = readingTime(post.body ?? "");

const siteUrl = Astro.site ?? Astro.url;
const canonicalUrl = new URL(`/blog/${post.id}/`, siteUrl).toString();
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  readingTime={reading}
>
  <Content />

  <Fragment slot="after-content">
    <ShareButtons url={canonicalUrl} title={post.data.title} description={post.data.description} />
    <RelatedPosts currentSlug={post.id} currentTags={post.data.tags} limit={3} />
    <GiscusComments />
  </Fragment>
</BlogLayout>
