---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, tags = [], heroImage } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdateDate = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — Vineeth N K`} description={description} image={heroImage}>
  <article class="blog-post section">
    <header class="blog-header fade-in">
      <a href="/blog" class="blog-back">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
        </svg>
        Back to blog
      </a>

      <div class="blog-meta">
        <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        {updatedDate && (
          <span class="blog-updated">
            (Updated: <time datetime={updatedDate.toISOString()}>{formattedUpdateDate}</time>)
          </span>
        )}
      </div>

      <h1 class="blog-title">{title}</h1>
      <p class="blog-description">{description}</p>

      {tags.length > 0 && (
        <div class="blog-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="blog-content fade-in">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 760px;
  }

  .blog-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 2rem;
    transition: color 0.2s ease;
  }

  .blog-back:hover {
    color: var(--color-accent);
  }

  .blog-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .blog-updated {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .blog-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .blog-description {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* Blog prose styles */
  .blog-content {
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .blog-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .blog-content :global(h3) {
    font-size: 1.3rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .blog-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .blog-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-content :global(strong) {
    color: var(--color-heading);
    font-weight: 600;
  }

  .blog-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .blog-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .blog-content :global(code) {
    background-color: var(--color-bg-code);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    border: 1px solid var(--color-border);
  }

  .blog-content :global(pre) {
    background-color: var(--color-bg-code-block) !important;
    border: 1px solid var(--color-border-code-block);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.75rem 0;
    box-shadow: 0 1px 3px var(--color-shadow), 0 4px 12px var(--color-shadow);
  }

  .blog-content :global(pre code) {
    background: none;
    padding: 0;
    border: none;
    font-size: 0.88rem;
    line-height: 1.65;
  }

  .blog-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .blog-content :global(img) {
    max-width: 100%;
    border-radius: var(--radius-sm);
    margin: 1.5rem 0;
  }
</style>
