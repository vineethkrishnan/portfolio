---
const experiences = [
  {
    role: "Senior Full Stack Engineer",
    company: "BEO Software Pvt. Ltd",
    period: "Feb 2020 - Present",
    location: "Kochi, Kerala",
    description:
      "Building and maintaining production applications across the full stack for international clients. Lead backend architecture decisions, ship internal developer tooling, and contribute to open-source projects on the side.",
    technologies: ["TypeScript", "NestJS", "React", "Vue.js", "PHP", "PostgreSQL", "MySQL", "Docker", "AWS"],
    engagements: [
      {
        client: "Ayunis GmbH (formerly Locaboo GmbH)",
        location: "Munich, Germany",
        period: "Sep 2021 - Present",
        summary:
          "Full-stack work on the Ayunis platform across Vue.js, PHP, MySQL, and Docker, in a hybrid setup spanning German and Indian teams.",
      },
      {
        client: "LOY GmbH",
        location: "Munich, Germany",
        period: "Feb 2020 - Present",
        summary:
          "Developing and maintaining PHP-based applications for LOY's platform.",
      },
    ],
  },
  {
    role: "Senior PHP Developer",
    company: "SoarMorrow Solutions Pvt. Ltd.",
    period: "Aug 2014 - Feb 2020",
    location: "Kochi, Kerala",
    description:
      "Progressed from Web Developer to Senior PHP Developer over 5+ years. Built and maintained e-commerce platforms and web applications for international clients.",
    technologies: ["PHP", "Magento", "Shopware", "MySQL", "JavaScript", "jQuery"],
  },
  {
    role: "Software Engineer",
    company: "Mobicube Interactive Pvt. Ltd",
    period: "Dec 2012 - Aug 2014",
    location: "Kochi, Kerala",
    description:
      "Started professional career building web applications and mobile solutions. Gained foundational experience in full-cycle software development.",
    technologies: ["PHP", "MySQL", "JavaScript", "HTML", "CSS"],
  },
  {
    role: "Freelance Web Designer",
    company: "Self-employed",
    period: "Mar 2012 - Dec 2012",
    location: "Kerala",
    description:
      "Designed and developed websites for local businesses as a freelancer right after completing B.Tech.",
    technologies: ["HTML", "CSS", "JavaScript", "PHP"],
  },
];
---

<div class="section-divider"></div>

<section class="section" id="experience">
  <div class="fade-in">
    <div class="section-label">
      <span class="section-label-line"></span>
      <span class="section-label-prefix">~/experience</span>
    </div>
    <h2 class="section-title">Experience</h2>
    <p class="section-subtitle">Professional journey</p>
  </div>

  <div class="timeline">
    {experiences.map((exp, i) => (
      <div class={`timeline-item fade-in stagger-${i + 1}`}>
        <div class="timeline-marker">
          <div class="timeline-dot"></div>
        </div>

        <div class="timeline-card card">
          <div class="timeline-header">
            <div>
              <h3 class="timeline-role">{exp.role}</h3>
              <p class="timeline-company">{exp.company}</p>
            </div>
            <div class="timeline-meta">
              <span class="tag">{exp.period}</span>
              <span class="timeline-location">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" />
                </svg>
                {exp.location}
              </span>
            </div>
          </div>

          <p class="timeline-desc">{exp.description}</p>

          {exp.engagements && exp.engagements.length > 0 && (
            <div class="engagements">
              <p class="engagements-label">Client engagements</p>
              <ul class="engagements-list">
                {exp.engagements.map((eng) => (
                  <li class="engagement-item">
                    <div class="engagement-head">
                      <span class="engagement-client">{eng.client}</span>
                      <span class="engagement-period">{eng.period}</span>
                    </div>
                    <p class="engagement-summary">{eng.summary}</p>
                    <span class="engagement-location">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" />
                      </svg>
                      {eng.location}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="timeline-tags">
            {exp.technologies.map((tech) => (
              <span class="tag">{tech}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .timeline-item {
    display: flex;
    gap: 1.25rem;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 1.5rem;
  }

  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-gradient-from), var(--color-gradient-to));
    box-shadow: 0 0 0 4px var(--color-accent-subtle);
  }

  .timeline-card {
    padding: 1.5rem;
    flex: 1;
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.85rem;
    flex-wrap: wrap;
  }

  .timeline-role {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .timeline-company {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.88rem;
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
  }

  .timeline-location {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .timeline-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .engagements {
    margin: 0.5rem 0 1rem;
    padding: 1rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-sm);
    background-color: var(--color-accent-subtle);
  }

  .engagements-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.65rem;
  }

  .engagements-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .engagement-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .engagement-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .engagement-client {
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--color-text);
  }

  .engagement-period {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-text-muted);
  }

  .engagement-summary {
    font-size: 0.84rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .engagement-location {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.74rem;
    color: var(--color-text-muted);
  }

  .timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  @media (max-width: 640px) {
    .timeline-marker { display: none; }
    .timeline-meta { align-items: flex-start; }
  }
</style>
