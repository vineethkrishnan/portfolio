---
import ThemeSwitcher from "./ThemeSwitcher.astro";

const navLinks = [
  { label: "About", href: "/#about" },
  { label: "Skills", href: "/#skills" },
  { label: "Projects", href: "/#projects" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/#contact" },
];
---

<div class="scroll-progress" id="scroll-progress"></div>

<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo brand-mark" aria-label="Vineeth N K — home">
      <span class="brace brace-l">&#123;</span><span class="brand-name"><span class="brand-letter">V</span><span class="brand-letter">N</span><span class="brand-letter">K</span></span><span class="brace brace-r">&#125;</span>
    </a>

    <div class="nav-links" id="nav-links">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </div>

    <div class="nav-right">
      <ThemeSwitcher />
      <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line class="line1" x1="4" y1="6" x2="20" y2="6" />
          <line class="line2" x1="4" y1="12" x2="20" y2="12" />
          <line class="line3" x1="4" y1="18" x2="20" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--color-nav-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 1.5rem;
  }

  .nav-logo {
    font-size: 1.1rem;
    font-weight: 800;
    font-family: var(--font-mono);
    letter-spacing: -0.02em;
  }

  .brand-mark {
    display: inline-flex;
    align-items: baseline;
    color: var(--color-heading);
    transition: filter 0.3s ease;
    will-change: filter;
  }

  .brand-mark .brace {
    color: var(--color-accent);
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .brand-mark .brand-name {
    display: inline-flex;
  }

  .brand-mark .brand-letter {
    display: inline-block;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .brand-mark:hover .brace-l { transform: translateX(-3px) scale(1.15); }
  .brand-mark:hover .brace-r { transform: translateX(3px) scale(1.15); }
  .brand-mark:hover { filter: drop-shadow(0 0 6px var(--color-accent-glow)); }
  .brand-mark:hover .brand-letter:nth-child(1) { animation: brand-pop 0.5s 0s ease; }
  .brand-mark:hover .brand-letter:nth-child(2) { animation: brand-pop 0.5s 0.08s ease; }
  .brand-mark:hover .brand-letter:nth-child(3) { animation: brand-pop 0.5s 0.16s ease; }

  @keyframes brand-pop {
    0%, 100% { transform: translateY(0); color: inherit; }
    40% { transform: translateY(-2.5px) scale(1.12); color: var(--color-accent); }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-mark .brace,
    .brand-mark .brand-letter,
    .brand-mark { transition: none; }
    .brand-mark:hover .brand-letter { animation: none; }
  }

  .nav-links {
    display: none;
    gap: 1.75rem;
  }

  @media (min-width: 768px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    color: var(--color-text-muted);
    font-size: 0.82rem;
    font-weight: 500;
    transition: color 0.2s ease;
    position: relative;
    letter-spacing: 0.02em;
  }

  .nav-link:hover { color: var(--color-accent); }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: linear-gradient(90deg, var(--color-gradient-from), var(--color-gradient-to));
    transition: width 0.25s ease;
    border-radius: 1px;
  }

  .nav-link:hover::after { width: 100%; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .mobile-toggle {
    display: flex;
    padding: 4px;
    border: none;
    background: none;
    color: var(--color-text);
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .mobile-toggle { display: none; }
  }

  .mobile-toggle line {
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .mobile-toggle.open .line1 { transform: translateY(6px) rotate(45deg); }
  .mobile-toggle.open .line2 { opacity: 0; }
  .mobile-toggle.open .line3 { transform: translateY(-6px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .mobile-menu.open { display: flex; }

  @media (min-width: 768px) {
    .mobile-menu { display: none !important; }
  }

  .mobile-link {
    padding: 0.65rem 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-link:last-child { border-bottom: none; }
  .mobile-link:hover { color: var(--color-accent); }
</style>

<script>
  function initNav() {
    const toggle = document.getElementById("mobile-toggle");
    const menu = document.getElementById("mobile-menu");

    toggle?.addEventListener("click", () => {
      toggle.classList.toggle("open");
      menu?.classList.toggle("open");
    });

    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        toggle?.classList.remove("open");
        menu.classList.remove("open");
      });
    });

    // Scroll progress
    const bar = document.getElementById("scroll-progress");
    window.addEventListener("scroll", () => {
      const scrollTop = document.documentElement.scrollTop;
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
      if (bar) bar.style.width = `${progress}%`;
    }, { passive: true });
  }

  initNav();
  document.addEventListener("astro:after-swap", initNav);
</script>
