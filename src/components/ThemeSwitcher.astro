---
const themes = [
  { id: "minimal", label: "Minimal", icon: "sun" },
  { id: "terminal", label: "Terminal", icon: "terminal" },
  { id: "elegant", label: "Elegant", icon: "sparkles" },
];
---

<div class="theme-switcher" id="theme-switcher">
  {themes.map((theme) => (
    <button
      class="theme-btn"
      data-theme-value={theme.id}
      title={`Switch to ${theme.label} theme`}
      aria-label={`Switch to ${theme.label} theme`}
    >
      {theme.id === "minimal" && (
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
      )}
      {theme.id === "terminal" && (
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" />
        </svg>
      )}
      {theme.id === "elegant" && (
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3z" /><path d="M5 17l.5 1.5L7 19l-1.5.5L5 21l-.5-1.5L3 19l1.5-.5L5 17z" /><path d="M19 13l.5 1.5 1.5.5-1.5.5-.5 1.5-.5-1.5L17 15l1.5-.5.5-1.5z" />
        </svg>
      )}
      <span class="theme-label">{theme.label}</span>
    </button>
  ))}
</div>

<style>
  .theme-switcher {
    display: flex;
    gap: 4px;
    padding: 4px;
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .theme-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: none;
    border-radius: calc(var(--radius-sm) - 2px);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.8rem;
    font-family: var(--font-body);
    font-weight: 500;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .theme-btn:hover {
    color: var(--color-text);
    background-color: var(--color-bg-card);
  }

  .theme-btn.active {
    color: var(--color-accent);
    background-color: var(--color-bg-card);
    box-shadow: 0 1px 3px var(--color-shadow);
  }

  .theme-label {
    display: none;
  }

  @media (min-width: 640px) {
    .theme-label {
      display: inline;
    }
  }
</style>

<script>
  function initThemeSwitcher() {
    const saved = localStorage.getItem("portfolio-theme") || "terminal";
    document.documentElement.setAttribute("data-theme", saved);
    updateActiveButton(saved);

    document.querySelectorAll(".theme-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const theme = (btn as HTMLElement).dataset.themeValue!;
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem("portfolio-theme", theme);
        updateActiveButton(theme);
      });
    });
  }

  function updateActiveButton(theme: string) {
    document.querySelectorAll(".theme-btn").forEach((btn) => {
      btn.classList.toggle("active", (btn as HTMLElement).dataset.themeValue === theme);
    });
  }

  initThemeSwitcher();
  document.addEventListener("astro:after-swap", initThemeSwitcher);
</script>
