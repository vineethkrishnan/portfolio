---
const currentYear = new Date().getFullYear();

const socials = [
  {
    label: "GitHub",
    href: "https://github.com/vineethkrishnan",
    icon: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />`,
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/vineeth-n-k-40891265/",
    icon: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" />`,
  },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-left">
        <a href="/" class="footer-logo">
          <span class="gradient-text">&#123;VNK&#125;</span>
        </a>
        <p class="footer-tagline">Building tools, writing code, sharing knowledge.</p>
      </div>
      <div class="footer-socials">
        {socials.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label} class="footer-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={social.icon} />
          </a>
        ))}
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {currentYear} Vineeth N K</p>
      <p class="footer-built">Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-alt);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 1.5rem;
  }

  .footer-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-logo {
    font-size: 1rem;
    font-weight: 800;
    font-family: var(--font-mono);
    display: block;
    margin-bottom: 0.4rem;
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .footer-socials {
    display: flex;
    gap: 0.5rem;
  }

  .footer-link {
    color: var(--color-text-muted);
    transition: color 0.2s ease, transform 0.2s ease;
    display: flex;
    align-items: center;
    padding: 8px;
    border-radius: var(--radius-xs);
    border: 1px solid transparent;
  }

  .footer-link:hover {
    color: var(--color-accent);
    border-color: var(--color-border);
    transform: translateY(-2px);
  }

  .footer-bottom {
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }

  .footer-built a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-built a:hover {
    color: var(--color-accent);
  }
</style>
