---
import { getCollection } from "astro:content";

interface Props {
  currentSlug: string;
  currentTags: string[];
  limit?: number;
}

const { currentSlug, currentTags, limit = 3 } = Astro.props;

const allPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.id !== currentSlug);

const scored = allPosts
  .map((post) => {
    const overlap = post.data.tags.filter((t) => currentTags.includes(t)).length;
    return { post, overlap };
  })
  .filter((entry) => entry.overlap > 0)
  .sort((a, b) => {
    if (b.overlap !== a.overlap) return b.overlap - a.overlap;
    return b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf();
  })
  .slice(0, limit);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

{scored.length > 0 && (
  <aside class="related-posts">
    <h2 class="related-title">Related posts</h2>
    <ul class="related-list">
      {scored.map(({ post }) => (
        <li>
          <a href={`/blog/${post.id}/`} class="related-card">
            <h3 class="related-card-title">{post.data.title}</h3>
            <p class="related-card-desc">{post.data.description}</p>
            <div class="related-card-meta">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              {post.data.tags.length > 0 && (
                <span class="related-card-tags">{post.data.tags.slice(0, 3).join(" · ")}</span>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .related-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .related-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.8rem;
  }

  .related-card {
    display: block;
    padding: 1rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-card);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
  }

  .related-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .related-card-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
    color: var(--color-heading);
    line-height: 1.3;
  }

  .related-card-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0 0 0.6rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    font-size: 0.74rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .related-card-tags::before {
    content: "·";
    margin-right: 0.5rem;
    opacity: 0.6;
  }
</style>
